# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/invoiceflow"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
APP_URL="http://localhost:5173"

# ─── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"
ADMIN_CLIENT_URL="http://localhost:5174"

# ─── Admin Access ───────────────────────────────────────────────────────────────
# Comma-separated allowlist for owner/admin panel access.
ADMIN_EMAILS="owner@example.com"
# Optional: Comma-separated user IDs that should be admins.
ADMIN_USER_IDS=""

# ─── Email (SMTP / SendGrid) ───────────────────────────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your-sendgrid-api-key"
FROM_EMAIL="xpensist@gmail.com"
FROM_NAME="Xpensist"
# Optional: where support form messages are delivered. Falls back to FROM_EMAIL.
SUPPORT_EMAIL="xpensist@gmail.com"

# ─── Cloudflare R2 (optional attachments) ──────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="invoiceflow-attachments"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"

# ─── Stripe Billing (subscriptions) ───────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_STARTER="price_xxx"
STRIPE_PRICE_PROFESSIONAL="price_xxx"
STRIPE_PRICE_BUSINESS="price_xxx"

# ─── Automation ──────────────────────────────────────────────────────────────
# Run `npm run jobs:invoice-reminders` on a daily scheduler to send reminder emails.
